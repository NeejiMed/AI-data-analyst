# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# LLM
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database
DATABASE_URL=sqlite:///./data/analyst.db

# Vector DB
CHROMA_PERSIST_DIR=./chroma_db

# Security
SECRET_KEY=change-this-in-production